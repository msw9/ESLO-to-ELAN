, {"id": 41, "seek": 7970, "start": 84.4, "end": 85.10000000000001, "text": " Tr\u00e8s bien !", "tokens": [50599, 1765, 3645, 3610, 2298, 50634], "temperature": 0.0, "avg_logprob": -0.1939958398992365, "compression_ratio": 1.7066326530612246, "no_speech_prob": 0.04039527103304863}, {"id": 42, "seek": 7970, "start": 85.10000000000001, "end": 89.8, "text": " Et enfin, si vous deviez prendre une photo d'Orl\u00e9ans, vous la d\u00e9criverez o\u00f9 ?", "tokens": [50634, 3790, 25059, 11, 1511, 2630, 1905, 18812, 16566, 2251, 5052, 274, 6, 21520, 29728, 599, 11, 2630, 635, 2795, 1142, 5887, 89, 9068, 2506, 50869], "temperature": 0.0, "avg_logprob": -0.1939958398992365, "compression_ratio": 1.7066326530612246, "no_speech_prob": 0.04039527103304863}, {"id": 43, "seek": 7970, "start": 89.8, "end": 91.9, "text": " En France, la photo d'Orl\u00e9ans ?", "tokens": [50869, 2193, 6190, 11, 635, 5052, 274, 6, 21520, 29728, 599, 2506, 50974], "temperature": 0.0, "avg_logprob": -0.1939958398992365, "compression_ratio": 1.7066326530612246, "no_speech_prob": 0.04039527103304863}, {"id": 44, "seek": 7970, "start": 91.9, "end": 94.60000000000001, "text": " Ah, \u00e7a, c'est une question que je ne sais pas du tout !", "tokens": [50974, 2438, 11, 2788, 11, 269, 6, 377, 2251, 1168, 631, 1506, 408, 11757, 1736, 1581, 3486, 2298, 51109], "temperature": 0.0, "avg_logprob": -0.1939958398992365, "compression_ratio": 1.7066326530612246, "no_speech_prob": 0.04039527103304863}, {"id": 45, "seek": 7970, "start": 94.60000000000001, "end": 98.9, "text": " Par exemple, qui vous plait plus qu'un autre, ou un quartier, un lieu...", "tokens": [51109, 3457, 12223, 11, 1956, 2630, 499, 1001, 1804, 421, 6, 409, 15081, 11, 2820, 517, 20837, 811, 11, 517, 26036, 485, 51324], "temperature": 0.0, "avg_logprob": -0.1939958398992365, "compression_ratio": 1.7066326530612246, "no_speech_prob": 0.04039527103304863}, {"id": 46, "seek": 7970, "start": 98.9, "end": 100.30000000000001, "text": " Du tout !", "tokens": [51324, 5153, 3486, 2298, 51394], "temperature": 0.0, "avg_logprob": -0.1939958398992365, "compression_ratio": 1.7066326530612246, "no_speech_prob": 0.04039527103304863}, {"id": 47, "seek": 7970, "start": 100.30000000000001, "end": 102.30000000000001, "text": " Est-ce que je peux vous donner votre \u00e2ge et votre profession, s'il vous pla\u00eet ?", "tokens": [51394, 4410, 12, 384, 631, 1506, 14844, 2630, 20882, 10087, 20621, 432, 1030, 10087, 7032, 11, 262, 6, 388, 2630, 15256, 20028, 2506, 51494], "temperature": 0.0, "avg_logprob": -0.1939958398992365, "compression_ratio": 1.7066326530612246, "no_speech_prob": 0.04039527103304863}, {"id": 48, "seek": 7970, "start": 102.30000000000001, "end": 104.10000000000001, "text": " 23 ans, pour les agents de s\u00e9curit\u00e9 !", "tokens": [51494, 6673, 1567, 11, 2016, 1512, 12554, 368, 37600, 2298, 51584], "temperature": 0.0, "avg_logprob": -0.1939958398992365, "compression_ratio": 1.7066326530612246, "no_speech_prob": 0.04039527103304863}, {"id": 49, "seek": 7970, "start": 104.10000000000001, "end": 104.9, "text": " D'accord, tr\u00e8s bien !", "tokens": [51584, 413, 6, 19947, 11, 5732, 3610, 2298, 51624], "temperature": 0.0, "avg_logprob": -0.1939958398992365, "compression_ratio": 1.7066326530612246, "no_speech_prob": 0.04039527103304863}, {"id": 50, "seek": 7970, "start": 104.9, "end": 109.30000000000001, "text": " Enfin, je vais vous demander de me redire le trajet pour aller \u00e0 la merine et enregistrer cette fois, s'il vous pla\u00eet !", "tokens": [51624, 35861, 11, 1506, 9369, 2630, 39169, 368, 385, 2182, 621, 476, 944, 7108, 2016, 8722, 1531, 635, 3551, 533, 1030, 465, 48933, 9797, 5550, 9576, 11, 262, 6, 388, 2630, 15256, 20028, 2298, 51844], "temperature": 0.0, "avg_logprob": -0.1939958398992365, "compression_ratio": 1.7066326530612246, "no_speech_prob": 0.04039527103304863}, {"id": 51, "seek": 10930, "start": 109.3, "end": 110.89999999999999, "text": " D'accord, alors...", "tokens": [50364, 413, 6, 19947, 11, 11246, 485, 50444], "temperature": 0.0, "avg_logprob": -0.3759678288509971, "compression_ratio": 1.575, "no_speech_prob": 0.14376473426818848}, {"id": 52, "seek": 10930, "start": 110.89999999999999, "end": 115.3, "text": " Cal\u00e9drale d'Orl\u00e9ans, la premi\u00e8re \u00e0 gauche, parce que tu verras, il y a des escaliers...", "tokens": [50444, 3511, 7811, 47282, 274, 6, 21520, 29728, 599, 11, 635, 17872, 1531, 36724, 11, 6992, 631, 2604, 1306, 3906, 11, 1930, 288, 257, 730, 17871, 4890, 485, 50664], "temperature": 0.0, "avg_logprob": -0.3759678288509971, "compression_ratio": 1.575, "no_speech_prob": 0.14376473426818848}, {"id": 53, "seek": 10930, "start": 115.3, "end": 116.3, "text": " D'accord, et c'est l\u00e0 !", "tokens": [50664, 413, 6, 19947, 11, 1030, 269, 6, 377, 3684, 2298, 50714], "temperature": 0.0, "avg_logprob": -0.3759678288509971, "compression_ratio": 1.575, "no_speech_prob": 0.14376473426818848}, {"id": 54, "seek": 10930, "start": 116.3, "end": 118.8, "text": " Et pour le pire des cas, tout le monde n'est pas assorti !", "tokens": [50714, 3790, 2016, 476, 280, 621, 730, 3058, 11, 3486, 476, 10431, 297, 6, 377, 1736, 1256, 477, 72, 2298, 50839], "temperature": 0.0, "avg_logprob": -0.3759678288509971, "compression_ratio": 1.575, "no_speech_prob": 0.14376473426818848}, {"id": 55, "seek": 10930, "start": 118.8, "end": 119.8, "text": " D'accord, merci beaucoup !", "tokens": [50839, 413, 6, 19947, 11, 30532, 8796, 2298, 50889], "temperature": 0.0, "avg_logprob": -0.3759678288509971, "compression_ratio": 1.575, "no_speech_prob": 0.14376473426818848}, {"id": 56, "seek": 10930, "start": 119.8, "end": 120.3, "text": " Au revoir, merci !", "tokens": [50889, 12160, 319, 8823, 11, 30532, 2298, 50914], "temperature": 0.0, "avg_logprob": -0.3759678288509971, "compression_ratio": 1.575, "no_speech_prob": 0.14376473426818848}, {"id": 57, "seek": 10930, "start": 120.3, "end": 120.8, "text": " Bonne journ\u00e9e, monsieur !", "tokens": [50914, 7368, 716, 34277, 11, 36507, 2298, 50939], "temperature": 0.0, "avg_logprob": -0.3759678288509971, "compression_ratio": 1.575, "no_speech_prob": 0.14376473426818848}, {"id": 58, "seek": 10930, "start": 120.8, "end": 122.1, "text": " Au revoir, surtout, et puis merci !", "tokens": [50939, 12160, 319, 8823, 11, 19903, 11, 1030, 9093, 30532, 2298, 51004], "temperature": 0.0, "avg_logprob": -0.3759678288509971, "compression_ratio": 1.575, "no_speech_prob": 0.14376473426818848}, {"id": 59, "seek": 10930, "start": 122.1, "end": 122.6, "text": " Au revoir !", "tokens": [51004, 12160, 319, 8823, 2298, 51029], "temperature": 0.0, "avg_logprob": -0.3759678288509971, "compression_ratio": 1.575, "no_speech_prob": 0.14376473426818848}], "language": "French"}