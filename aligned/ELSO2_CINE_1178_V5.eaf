                <ANNOTATION_VALUE>Oui.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>J'en ai vu un que le premier, alors c'est sûr. Il m'a manqué un morceau, mais non, je trouvais ça pas mal.</ANNOTATION_VALUE>
